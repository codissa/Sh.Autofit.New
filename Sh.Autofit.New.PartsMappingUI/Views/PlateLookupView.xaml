<UserControl x:Class="Sh.Autofit.New.PartsMappingUI.Views.PlateLookupView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             FlowDirection="RightToLeft">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="170"/>
        </Grid.RowDefinitions>

        <!-- Search Section -->
        <GroupBox Grid.Row="0" Header="חיפוש לפי מספר רישוי" Padding="10" Margin="0,0,0,10">
            <StackPanel>
                <DockPanel Margin="0,0,0,10">
                    <Button DockPanel.Dock="Left"
                            Content="🔍 חפש"
                            Command="{Binding SearchPlateCommand}"
                            Padding="20,8"
                            Margin="10,0,0,0"
                            FontSize="14"
                            FontWeight="Bold"/>
                    <Button DockPanel.Dock="Left"
                            Content="🗑️ נקה"
                            Command="{Binding ClearCommand}"
                            Padding="15,8"
                            Margin="10,0,0,0"
                            FontSize="14"/>
                    <Button DockPanel.Dock="Left"
                            Content="❌ ביטול"
                            Command="{Binding CancelSearchCommand}"
                            Padding="15,8"
                            Margin="10,0,0,0"
                            FontSize="14"
                            Background="#F44336"
                            Foreground="White"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBox Text="{Binding PlateNumber, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16"
                             Padding="8"
                             VerticalContentAlignment="Center">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchPlateCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                </DockPanel>

                <!-- Status Message -->
                <TextBlock Text="{Binding StatusMessage}"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="Green"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusMessage, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Search Duration Timer -->
                <TextBlock Text="{Binding SearchDuration}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Foreground="#4CAF50"
                           Margin="0,3,0,0"
                           TextWrapping="Wrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SearchDuration, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <!-- Loading Indicator -->
                <ProgressBar IsIndeterminate="True"
                             Height="4"
                             Margin="0,10,0,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </GroupBox>

        <!-- Government Vehicle Data -->
        <GroupBox Grid.Row="1"
                  Padding="8"
                  Margin="0,0,0,8"
                  Visibility="{Binding GovernmentVehicle, Converter={StaticResource NullToVisibilityConverter}}">
            <GroupBox.Header>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="נתוני רכב ממשרד התחבורה" FontWeight="Bold"/>
                    <TextBlock Text=" - ירד מהכביש"
                               Foreground="Red"
                               FontWeight="Bold"
                               Margin="10,0,0,0"
                               Visibility="{Binding IsOffRoad, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text=" - ייבוא אישי"
                               Foreground="Red"
                               FontWeight="Bold"
                               Margin="10,0,0,0"
                               Visibility="{Binding IsPersonalImport, Converter={StaticResource BoolToVisibilityConverter}}"/>
                </StackPanel>
            </GroupBox.Header>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Column 1 - Manufacturer & Model Info -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,5,0">
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="יצרן: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.ManufacturerName}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="קוד יצרן: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.ManufacturerCode}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="דגם: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.ModelName}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="קוד דגם: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.ModelCode}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="שם מסחרי: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.CommercialName}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Column 2 - Vehicle Details -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,5,0">
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="שנת ייצור: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.ManufacturingYear}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="סוג דלק: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.FuelType}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="מרכב: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.TrimLevel}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="רמת גימור: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.TrimLevel}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="צבע: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.ColorName}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Column 3 - Engine & Technical -->
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,5,0">
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="דגם מנוע: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.EngineModel}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="נפח מנוע: " FontWeight="Bold"/>
                        <Run Text="{Binding DisplayEngineVolume, Mode=OneWay}"/>
                        <Run Text=" סמ&quot;ק"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="מספר מנוע: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.EngineNumber}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="קבוצת זיהום: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.PollutionGroup}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="צמיג קדמי: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.FrontTire}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Column 4 - VIN & Dates -->
                <StackPanel Grid.Row="0" Grid.Column="3">
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="VIN: " FontWeight="Bold"/>
                    </TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0"
                                   Text="{Binding CleanVinNumber}"
                                   FontSize="12"
                                   FontFamily="Consolas"
                                   Foreground="#0066CC"
                                   Cursor="Hand"
                                   TextDecorations="Underline"
                                   ToolTip="לחץ להעתקה">
                            <TextBlock.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding CopyVinToClipboardCommand}"/>
                            </TextBlock.InputBindings>
                        </TextBlock>

                        <!-- Copied Popup -->
                        <Border Grid.Column="1"
                                Background="#4CAF50"
                                CornerRadius="3"
                                Padding="6,3"
                                Margin="8,0,0,0"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Left"
                                Visibility="{Binding ShowCopiedPopup, Converter={StaticResource BoolToVisibilityConverter}}">
                            <TextBlock Text="✓ הועתק"
                                       Foreground="White"
                                       FontSize="10"
                                       FontWeight="Bold"/>
                        </Border>
                    </Grid>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="צמיג אחורי: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.RearTire}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="בעלות: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.OwnershipType}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2" FontSize="13">
                        <Run Text="טסט אחרון: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.LastTestDate}"/>
                    </TextBlock>

                </StackPanel>

                <!-- Row 2 - Additional info -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Margin="0,2,15,2" FontSize="13">
                        <Run Text="תוקף רישיון: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.ValidityDate}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="13">
                        <Run Text="תאריך עלייה לכביש: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.RoadDate}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="13">
                        <Run Text="הוראת רישום: " FontWeight="Bold"/>
                        <Run Text="{Binding GovernmentVehicle.RegistrationInstruction}"/>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </GroupBox>

        <!-- Matched Vehicle Section -->
        <GroupBox Grid.Row="2"
                  Padding="8"
                  Margin="0,0,0,8"
                  Visibility="{Binding MatchedVehicle, Converter={StaticResource NullToVisibilityConverter}}">
            <GroupBox.Header>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock Text="רכב תואם במערכת" FontWeight="Bold"/>
                        <TextBlock Text=" - ירד מהכביש"
                                   Foreground="Red"
                                   FontWeight="Bold"
                                   Margin="10,0,0,0"
                                   Visibility="{Binding IsOffRoad, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock Text=" - ייבוא אישי"
                                   Foreground="Red"
                                   FontWeight="Bold"
                                   Margin="10,0,0,0"
                                   Visibility="{Binding IsPersonalImport, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    </StackPanel>

                    <!-- Coupling Info Button -->
                    <Button Grid.Column="1"
                            Command="{Binding ShowCouplingInfoCommand}"
                            CommandParameter="{Binding ConsolidatedModel}"
                            Content="🔗 הצג מידע צימוד"
                            FontSize="12"
                            Padding="8,4"
                            Margin="10,0,0,0"
                            Background="#FF9800"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="הצג מידע על דגמים מצומדים">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                 VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FB8C00"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </Button.Style>
                    </Button>
                </Grid>
            </GroupBox.Header>
            <StackPanel>
                <WrapPanel Orientation="Horizontal">
                    <TextBlock Margin="0,2,15,2" FontSize="14">
                        <Run Text="יצרן: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.ManufacturerName}"/>
                        <Run Text=" (" Foreground="Gray"/>
                        <Run Text="{Binding MatchedVehicle.ManufacturerShortName}" Foreground="Gray"/>
                        <Run Text=")" Foreground="Gray"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14">
                        <Run Text="דגם: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.ModelName}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14">
                        <Run Text="טווח שנים: " FontWeight="Bold"/>
                        <Run Text="{Binding DisplayYearRange, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14">
                        <Run Text="שם מסחרי: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.CommercialName}"/>
                    </TextBlock>
                </WrapPanel>
                <WrapPanel Orientation="Horizontal" Margin="0,5,0,0">
                    <TextBlock Margin="0,2,15,2" FontSize="14"
                               Visibility="{Binding MatchedVehicle.FuelTypeName, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="סוג דלק: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.FuelTypeName}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14"
                               Visibility="{Binding DisplayEngineVolume, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="נפח מנוע: " FontWeight="Bold"/>
                        <Run Text="{Binding DisplayEngineVolume, Mode=OneWay}"/>
                        <Run Text=" סמ&quot;ק"/>
                    </TextBlock>

                    <TextBlock Margin="0,2,15,2" FontSize="14"
                               Visibility="{Binding MatchedVehicle.EngineModel, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="דגם מנוע: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.EngineModel}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14"
                               Visibility="{Binding MatchedVehicle.TransmissionType, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="תיבת הילוכים: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.TransmissionType}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14"
                               Visibility="{Binding MatchedVehicle.FinishLevel, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="רמת גימור: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.FinishLevel}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14"
                               Visibility="{Binding MatchedVehicle.TrimLevel, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="מרכב: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.TrimLevel}"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14"
                               Visibility="{Binding MatchedVehicle.Horsepower, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="כוח סוס: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.Horsepower}"/>
                        <Run Text=" כ&quot;ס"/>
                    </TextBlock>
                    <TextBlock Margin="0,2,15,2" FontSize="14"
                               Visibility="{Binding MatchedVehicle.DriveType, Converter={StaticResource NullToVisibilityConverter}}">
                        <Run Text="הנעה: " FontWeight="Bold"/>
                        <Run Text="{Binding MatchedVehicle.DriveType}"/>
                    </TextBlock>
                </WrapPanel>

                <!-- Vehicle Quantity Data (loaded asynchronously) -->
                <Border Margin="0,8,0,2" Padding="10,6" Background="#E3F2FD"
                        CornerRadius="4" BorderBrush="#90CAF9" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoadingVehicleCounts}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ExactModelCount, Converter={StaticResource NullToVisibilityConverter}}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <!-- Loading indicator -->
                        <TextBlock Text="טוען נתוני כמות רכבים..."
                                   FontSize="12" Foreground="#1565C0"
                                   Visibility="{Binding IsLoadingVehicleCounts, Converter={StaticResource BoolToVisibilityConverter}}"/>

                        <!-- Exact model row -->
                        <StackPanel Orientation="Horizontal" Margin="0,2"
                                    Visibility="{Binding ExactModelCount, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="דגם מדויק:" FontWeight="Bold" FontSize="13" Foreground="#1565C0" Margin="0,0,12,0"/>
                            <TextBlock FontSize="13" Margin="0,0,12,0">
                                <Run Text="פעילים: " Foreground="#2E7D32"/>
                                <Run Text="{Binding ExactModelCount.Active, StringFormat=N0}" FontWeight="Bold" Foreground="#2E7D32"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Margin="0,0,12,0">
                                <Run Text="לא פעילים: " Foreground="#C62828"/>
                                <Run Text="{Binding ExactModelCount.Inactive, StringFormat=N0}" FontWeight="Bold" Foreground="#C62828"/>
                            </TextBlock>
                            <TextBlock FontSize="13">
                                <Run Text="סה&quot;כ: " Foreground="#0D47A1"/>
                                <Run Text="{Binding ExactModelCount.Total, StringFormat=N0}" FontWeight="Bold" Foreground="#0D47A1"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Consolidated total row (only when coupled models exist) -->
                        <StackPanel Orientation="Horizontal" Margin="0,2"
                                    Visibility="{Binding TotalConsolidatedCount, Converter={StaticResource NullToVisibilityConverter}}">
                            <TextBlock Text="כל הדגמים:" FontWeight="Bold" FontSize="13" Foreground="#1565C0" Margin="0,0,12,0"/>
                            <TextBlock FontSize="13" Margin="0,0,12,0">
                                <Run Text="פעילים: " Foreground="#2E7D32"/>
                                <Run Text="{Binding TotalConsolidatedCount.Active, StringFormat=N0}" FontWeight="Bold" Foreground="#2E7D32"/>
                            </TextBlock>
                            <TextBlock FontSize="13" Margin="0,0,12,0">
                                <Run Text="לא פעילים: " Foreground="#C62828"/>
                                <Run Text="{Binding TotalConsolidatedCount.Inactive, StringFormat=N0}" FontWeight="Bold" Foreground="#C62828"/>
                            </TextBlock>
                            <TextBlock FontSize="13">
                                <Run Text="סה&quot;כ: " Foreground="#0D47A1"/>
                                <Run Text="{Binding TotalConsolidatedCount.Total, StringFormat=N0}" FontWeight="Bold" Foreground="#0D47A1"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                    <Button Content="🔧 מיפוי מהיר"
                            Command="{Binding QuickMapCommand}"
                            Padding="12,6"
                            Margin="5,0"
                            FontSize="14"
                            FontWeight="Bold"/>
                    <Button Content="📋 הצג כל ההתאמות"
                            Command="{Binding ViewAllMatchesCommand}"
                            Padding="12,6"
                            Margin="5,0"
                            FontSize="14"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Mapped Parts Header -->
        <TextBlock Grid.Row="3"
                   Text="חלקים ממופים:"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,5"
                   Visibility="{Binding MatchedVehicle, Converter={StaticResource NullToVisibilityConverter}}"/>

        <!-- Mapped Parts List -->
        <DataGrid Grid.Row="4"
                  ItemsSource="{Binding MappedParts}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                            ScrollViewer.VerticalScrollBarVisibility="Auto"
          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#F5F5F5"
                  FontSize="13"
                  Visibility="{Binding MatchedVehicle, Converter={StaticResource NullToVisibilityConverter}}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Focusable" Value="False"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="Focusable" Value="False"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </DataGrid.CellStyle>
            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="קוד חלק" Binding="{Binding PartNumber}" Width="120"/>
                <DataGridTextColumn Header="שם חלק" Binding="{Binding PartName}" Width="*"/>
                <DataGridTextColumn Header="קטגוריה" Binding="{Binding Category}" Width="150"/>
                <DataGridTextColumn Header="יצרן" Binding="{Binding Manufacturer}" Width="150"/>
                <DataGridTextColumn Header="במלאי" Binding="{Binding StockStatusIcon, Mode=OneWay}" Width="60"/>
                <DataGridTemplateColumn Header="פעולות" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="🗑️ הסר"
                                   Command="{Binding DataContext.UnmapPartCommand,
                                            RelativeSource={RelativeSource AncestorType=UserControl}}"
                                   CommandParameter="{Binding}"
                                   Background="#F44336"
                                   Foreground="White"
                                   BorderThickness="0"
                                   Padding="8,4"
                                   Cursor="Hand"
                                   ToolTip="הסר מיפוי (לחץ לבחירת אפשרויות)">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="{TemplateBinding Background}"
                                                           CornerRadius="3"
                                                           Padding="{TemplateBinding Padding}">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#D32F2F"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Suggested Parts Section -->
        <Border Grid.Row="5"
               Background="#E8F5E9"
               BorderBrush="#4CAF50"
               BorderThickness="0,2,0,0"
               Padding="10"
                
               Margin="0,20,0,0"
               Visibility="{Binding SuggestedParts.Count, Converter={StaticResource CountToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Suggestions Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="💡 הצעות למיפוי"
                              FontSize="18"
                              FontWeight="Bold"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SuggestedParts.Count, StringFormat='({0})'}"
                              FontSize="15"
                              Foreground="#666"
                              Margin="8,0,0,0"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="- חלקים ממופים לרכבים דומים"
                              FontSize="13"
                              Foreground="#888"
                              Margin="12,0,0,0"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Suggestions DataGrid -->
                <DataGrid Grid.Row="1"
                         ItemsSource="{Binding SuggestedParts}"
                         AutoGenerateColumns="False"
                         IsReadOnly="True"
                         CanUserAddRows="False"
                         SelectionMode="Single"
                         GridLinesVisibility="Horizontal"
                         HeadersVisibility="Column"
                         Background="#E8F5E9"
                         AlternatingRowBackground="#C8E6C9"
                         FontSize="13"
                         MaxHeight="300">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Focusable" Value="False"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Focusable" Value="False"/>
                            <Setter Property="BorderThickness" Value="0"/>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="קוד חלק" Binding="{Binding PartNumber}" Width="120"/>
                        <DataGridTextColumn Header="שם חלק" Binding="{Binding PartName}" Width="*"/>
                        <DataGridTextColumn Header="קטגוריה" Binding="{Binding Category}" Width="150"/>
                        <DataGridTextColumn Header="ציון" Binding="{Binding RelevanceScoreDisplay}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#2E7D32"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="סיבה" Binding="{Binding RelevanceReason}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#388E3C"/>
                                    <Setter Property="FontSize" Value="12"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTemplateColumn Header="פעולות" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✓ מיפוי מהיר"
                                           Command="{Binding DataContext.QuickMapSuggestionCommand,
                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                           CommandParameter="{Binding}"
                                           Background="#4CAF50"
                                           Foreground="White"
                                           BorderThickness="0"
                                           Padding="10,5"
                                           Cursor="Hand"
                                           ToolTip="הוסף חלק זה לרכב הנוכחי">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                   CornerRadius="3"
                                                                   Padding="{TemplateBinding Padding}">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#45A049"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- No Results Message -->
        <Border Grid.Row="1" Grid.RowSpan="4"
                Background="White"
                BorderBrush="#E0E0E0"
                BorderThickness="2"
                CornerRadius="8"
                Padding="40">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasResults}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🔍" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                <TextBlock Text="הזן מספר רישוי לחיפוש רכב"
                           FontSize="18"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="#666"/>
                <TextBlock Text="המערכת תחפש ברשומות התחבורה ותמצא את החלקים הממופים"
                           FontSize="14"
                           HorizontalAlignment="Center"
                           Foreground="#999"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
